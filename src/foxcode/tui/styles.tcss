/* FoxCode TUI - Full TCSS style sheet.
   1:1 port of doge-code theme colors (converted to TCSS).
   Brand: #ffd56b (warm gold) */

Screen {
    background: #0d1117;
    color: #e6edf3;
}

/* -------- Header -------- */
Header {
    background: #161b22;
    color: #e6edf3;
    text-style: bold;
    height: 1;
    border-bottom: solid #30363d;
}

Header #logo {
    color: #ffd56b;
    text-style: bold;
}

Header #mode {
    color: #d29922;
}

Header #tokens {
    color: #3fb950;
}

/* -------- Footer -------- */
Footer {
    background: #161b22;
    color: #7d8590;
    height: 1;
    border-top: solid #30363d;
}

Footer > .footer--key {
    color: #ffd56b;
    background: #3a2418;
    text-style: bold;
}

Footer > .footer--description {
    color: #7d8590;
}

/* -------- Sidebar -------- */
Sidebar {
    width: 30;
    min-width: 24;
    background: #0d1117;
    border-right: solid #30363d;
}

Sidebar > .section {
    height: auto;
    padding: 1 1 0 1;
    color: #7d8590;
    text-style: bold;
}

Sidebar #sessions {
    background: transparent;
    height: 1fr;
    padding: 0 1;
}

Sidebar #sessions SessionRow {
    background: transparent;
    color: #e6edf3;
    padding: 0 1;
    height: auto;
}

Sidebar #sessions SessionRow.--highlight {
    background: #1c2128;
    color: #ffd56b;
}

Sidebar Button#new-session {
    margin: 1 1 0 1;
    width: 1fr;
    background: #1c2128;
    color: #ffd56b;
    border: round #ffd56b;
}

Sidebar Button#new-session:hover {
    background: #3a2418;
    color: #ffe18c;
}

/* -------- Chat / message list -------- */
VirtualMessageList {
    background: #0d1117;
    padding: 1 2;
    scrollbar-gutter: stable;
    height: 1fr;
    align-vertical: bottom;
    align-horizontal: left;
}

VirtualMessageList > .banner {
    background: #161b22;
    border: round #30363d;
    padding: 1 2;
    margin: 0 0 1 0;
    color: #e6edf3;
}

/* -------- Spinner -------- */
SpinnerWidget {
    height: auto;
    padding: 0 2;
    background: #0d1117;
    color: #ffd56b;
}

/* -------- Messages -------- */
MessageWidget {
    margin: 0 0 1 0;
    padding: 0 1;
}

MessageWidget.selected {
    background: #1c2128;
    border: round #ffd56b;
}

MessageWidget.-role-user {
    border-left: thick #79c0ff;
}

MessageWidget.-role-assistant {
    border-left: thick #ffd56b;
}

MessageWidget.-role-tool {
    border-left: thick #a371f7;
    color: #a371f7;
}

MessageWidget.-role-system {
    border-left: thick #7d8590;
    color: #7d8590;
}

MessageWidget > .role {
    color: #ffd56b;
    text-style: bold;
    margin-bottom: 0;
}

MessageWidget.-role-user > .role {
    color: #79c0ff;
}

MessageWidget.-role-tool > .role {
    color: #a371f7;
}

MessageWidget.-role-system > .role {
    color: #7d8590;
}

MessageWidget > .body {
    color: #e6edf3;
}

/* -------- Main panel layout -------- */
#body {
    height: 1fr;
}

#main-panel {
    height: 1fr;
    width: 1fr;
}

/* -------- Input panel -------- */
PromptInput {
    height: auto;
    max-height: 9;
    background: #161b22;
    border-top: solid #30363d;
    padding: 0 1;
    position: relative;
}

/* -------- Status bar (below input) -------- */
#status-bar {
    height: auto;
    background: #161b22;
    color: #7d8590;
    padding: 0 1;
    border-top: solid #30363d;
}

/* -------- Command autocomplete -------- */
/* overlay:screen keeps the popup out of PromptInput's total_region so it
   never affects auto-height. position:absolute resets the origin to the
   parent content box, so the popup is offset downward so its bottom edge
   sits flush against PromptInput's top border. The compositor gives overlay
   widgets a full-screen clip so they are never cropped by overflow:hidden. */
#cmd-suggest {
    position: absolute;
    overlay: screen;
    offset: 0 0;
    height: auto;
    max-height: 14;
    margin: 0 1;
    background: #161b22;
    border: round #ffd56b;
    padding: 0 1;
}

PromptInput > .hint {
    color: #7d8590;
    height: 1;
    padding: 0 1;
}

PromptInput TextArea {
    background: #0d1117;
    border: round #30363d;
    color: #e6edf3;
    min-height: 1;
    max-height: 6;
    min-width: 20;
    padding: 0 1;
    width: 1fr;
}

PromptInput TextArea:focus {
    border: round #ffd56b;
}

PromptInput TextArea > .text-area--cursor {
    color: #ffd56b;
    background: transparent;
    text-style: reverse;
}

PromptInput TextArea > .text-area--placeholder {
    color: #545d68;
    text-style: italic;
}

PromptInput TextArea > .text-area--selection {
    background: #1f6feb;
}

PromptInput Button#send {
    background: #ffd56b;
    color: #0d1117;
    text-style: bold;
    border: none;
    width: 12;
    margin-top: 0;
    min-width: 12;
}

PromptInput Button#send:hover {
    background: #ffe18c;
}

PromptInput Button#send:disabled {
    background: #30363d;
    color: #7d8590;
}

PromptInput .input-row {
    height: auto;
    align: right top;
    min-height: 1;
}

PromptInput .prompt-char {
    color: #ffd56b;
    text-style: bold;
    height: 1;
    width: auto;
    padding: 0 0 0 1;
    content-align: center middle;
}

/* -------- Welcome screen -------- */
WelcomeScreen {
    align: center middle;
    background: #0d1117;
}

WelcomeScreen > .welcome-art {
    width: 58;
    height: auto;
    color: #e6edf3;
}

WelcomeScreen > .welcome-hint {
    color: #7d8590;
    margin-top: 2;
    text-style: italic;
}

/* -------- Modal (dialog) -------- */
ModalScreen {
    align: center middle;
    background: #0d1117 80%;
}

ModalScreen > .modal {
    width: 70;
    max-width: 90%;
    height: auto;
    background: #161b22;
    border: round #ffd56b;
    padding: 1 2;
}

ModalScreen > .modal > .title {
    color: #ffd56b;
    text-style: bold;
    margin-bottom: 1;
}

ModalScreen > .modal > .body {
    color: #e6edf3;
}

ModalScreen > .modal > .keys {
    margin-top: 1;
    color: #7d8590;
}

/* -------- Dialog actions -------- */
.dialog-actions {
    height: auto;
    align: right middle;
    margin-top: 1;
}

.dialog-actions Button {
    margin-left: 1;
}

/* -------- Diff viewer -------- */
DiffViewer {
    background: #0d1117;
    padding: 1;
}

DiffViewer > .diff-header {
    color: #ffd56b;
    text-style: bold;
    margin-bottom: 1;
}

/* -------- Permission dialog -------- */
PermissionRequest {
    background: #161b22;
    border: round #ffd56b;
    padding: 1 2;
}

PermissionRequest > .title {
    color: #ffd56b;
    text-style: bold;
    margin-bottom: 1;
}

PermissionRequest > .tool-name {
    color: #e6edf3;
    text-style: bold;
    margin-bottom: 1;
}

/* -------- Cost warning -------- */
CostWarning {
    background: #161b22;
    border: round #ffd56b;
    padding: 1 2;
}

CostWarning > .title {
    color: #ffd56b;
    text-style: bold;
    margin-bottom: 1;
}

/* -------- Divider -------- */
Divider {
    color: #7d8590;
    margin: 1 0;
}

/* -------- Loading state -------- */
LoadingState {
    color: #7d8590;
    text-style: italic;
}

/* -------- Config form (interactive /openai, /shunxapi) -------- */
ConfigFormScreen > .config-form {
    width: 62;
    max-width: 92%;
    height: auto;
    background: #161b22;
    border: round #ffd56b;
    padding: 1 2;
}

ConfigFormScreen > .config-form > .title {
    color: #ffd56b;
    text-style: bold;
}

ConfigFormScreen > .config-form > .subtitle {
    color: #7d8590;
    margin-bottom: 1;
}

ConfigFormScreen > .config-form > .field-label {
    color: #e6edf3;
    margin-top: 1;
}

ConfigFormScreen > .config-form Input {
    background: #0d1117;
    border: round #30363d;
    color: #e6edf3;
    margin-bottom: 1;
}

ConfigFormScreen > .config-form Input:focus {
    border: round #ffd56b;
}
